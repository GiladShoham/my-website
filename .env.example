# ---- Client (committed in .env; the app id is public) ----
# InstantDB application id. Ships in the browser bundle. Client writes are gated
# by instant.perms.ts.
NEXT_PUBLIC_INSTANT_APP_ID=your-instantdb-app-id

# ---- Server (SECRET — set in .env.local for local dev, and in your host env) ----
# Admin token for server-side SSR/ISR reads (src/lib/db-admin.ts) and the
# one-time data-migration scripts in ./scripts. Never commit this.
INSTANT_ADMIN_TOKEN=your-instantdb-admin-token

# Used only by the migration scripts in ./scripts (alias of the app id above).
INSTANT_APP_ID=your-instantdb-app-id

# ---- Contact-form notification email (server-side; src/lib/contact-notification.ts) ----
# RESEND_API_KEY is a SECRET. TO/FROM are optional (defaults match the old
# Supabase edge function: to shoham.gilad@gmail.com, from me@gilad.dev).
RESEND_API_KEY=your-resend-api-key
CONTACT_NOTIFICATION_TO=shoham.gilad@gmail.com
CONTACT_NOTIFICATION_FROM=me@gilad.dev

# ---- One-time data migration only (read-only Supabase access) ----
# Not required if migrating via the Supabase MCP. The service role key is a
# SECRET; delete after the migration is done.
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
