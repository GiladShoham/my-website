# ---- Client (committed in .env; the app id is public) ----
# InstantDB application id. Ships in the browser bundle.
VITE_INSTANT_APP_ID=

# ---- Server / scripts (put these in .env.local, which is git-ignored) ----
# Used by the InstantDB CLI and the data-migration scripts in ./scripts.
INSTANT_APP_ID=
INSTANT_ADMIN_TOKEN=

# ---- One-time data migration only (put in .env.local, never commit) ----
# Your Supabase project URL and service role key, used by scripts/export-supabase.mjs
# to read existing rows out of Supabase. Delete after the migration is done.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
