# InstantDB app id. Public — it ships in the browser bundle (client writes are
# gated by instant.perms.ts), so it is safe to commit.
NEXT_PUBLIC_INSTANT_APP_ID=5afcee9b-cad6-4d63-bb7d-45a75ae5ff62

# NOTE: INSTANT_ADMIN_TOKEN is a SECRET (server-side SSR reads + data scripts).
