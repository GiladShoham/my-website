# InstantDB app id — this is public (it ships in the client bundle), safe to commit.
# Get it from `npx instant-cli info` after creating the app, or from the dashboard.
VITE_INSTANT_APP_ID=__REPLACE_WITH_YOUR_APP_ID__

# NOTE: The admin token is a SECRET. Do NOT put it here (this file is committed).
# Put INSTANT_APP_ID and INSTANT_ADMIN_TOKEN in .env.local (git-ignored).
# See .env.example and RUNBOOK.md.
