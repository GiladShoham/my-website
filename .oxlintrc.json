{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "nextjs", "jsx-a11y"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "react/no-unescaped-entities": "off",
    "nextjs/no-img-element": "off"
  },
  "ignorePatterns": [".next/**", "out/**", "build/**", "next-env.d.ts"]
}
